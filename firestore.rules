rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cardStatuses/{cardId} {
      function isKnownCard() {
        return cardId in ['iki', 'maxima', 'lidl', 'norfa', 'promo', 'senukai'];
      }

      function hasValidData() {
        return request.resource.data.keys().hasOnly(['working', 'updatedAt'])
          && request.resource.data.working is bool
          && request.resource.data.updatedAt == request.time;
      }

      allow read: if true;
      allow create, update: if isKnownCard() && hasValidData();
      allow delete: if false;
    }
  }
}
